{
  "manifest_version": 3,
  "name": "Parallel Reading Web Pages",
  "version": "1.0",
  "description": "Parallel reading web pages in English, Spanish, and other languages.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Parallel Reading Web Pages"
  },
  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_icon": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png"
    }
  }
}
